# Copier en .env et adapter les valeurs.
# Le fichier .env est exclu de git (.gitignore).

# ============ PostgreSQL (DB clients + paiements) ============
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/whatsapp_test

# ============ Service IA local (ai_ocr) ============
AI_OCR_URL=http://127.0.0.1:8008

# ============ UCRM (CRM/billing) ============
# UCRM_BASE_URL = racine hôte (sans préfixe). Le code construit /api/v1.0/payments
# (auth X-Auth-App-Key) et /crm/api/v1.0/clients/{id} (auth x-auth-token).
UCRM_BASE_URL=http://127.0.0.1:9001
UCRM_APP_KEY=fake-app-key
UCRM_CRM_TOKEN=fake-crm-token
# Constantes du compte UCRM (à mettre à jour en prod).
UCRM_METHOD_ID=c081a41c-ed63-49e9-abeb-c099e4297316
UCRM_USER_ID=1639
UCRM_CURRENCY=MRU
# En prod :
# UCRM_BASE_URL=https://13.62.145.152
# UCRM_APP_KEY=<vraie-cle-applicative>
# UCRM_CRM_TOKEN=<token-uuid-crm>

# ============ MikroTik (routeur) ============
# MIKROTIK_DRIVER : "http" pour le fake (dev/tests) ou "routeros" pour la prod (librouteros).
MIKROTIK_DRIVER=http
MIKROTIK_BASE_URL=http://127.0.0.1:9002
# En prod (RouterOS API binaire, port 8728) :
# MIKROTIK_DRIVER=routeros
# MIKROTIK_HOST=102.215.95.1
# MIKROTIK_USER=Suspension
# MIKROTIK_PASSWORD=<password>
# MIKROTIK_PORT=8728
# MIKROTIK_TIMEOUT=15

# ============ UltraMsg (passerelle WhatsApp) ============
ULTRAMSG_BASE_URL=http://127.0.0.1:9003
ULTRAMSG_INSTANCE=instance62746
ULTRAMSG_TOKEN=fake-token

# ============ Notification support (paiements en échec) ============
# Destinataire WhatsApp qui reçoit les notifications quand un paiement échoue
# (client introuvable, OCR raté, CRM injoignable, sur-paiement…). Accepte :
#   - un numéro individuel  : +22248783201
#   - un ID de groupe       : 120363xxxxxxxxxxxx@g.us
# Laisser vide pour désactiver les notifications.
SUPPORT_RECIPIENT=

# ============ Queue + dataset (chemins runtime) ============
# Par défaut, on utilise data/queue.db et data/dataset/ à la racine projet.
# Ces valeurs peuvent être surchargées :
# QUEUE_DB_PATH=d:/Whatsapp/data/queue.db
# AI_OCR_DATASET_PATH=d:/Whatsapp/data/dataset

# ============ PDF du reçu (généré côté PHP existant) ============
PDF_URL_TEMPLATE=http://127.0.0.1:9003/fake-pdf/{payment_id}
# En prod :
# PDF_URL_TEMPLATE=http://13.49.185.225/uisp/paymentrecue.php?id={payment_id}

# ============ API consultation client (/api/clients/lookup) ============
# Clé partagée requise dans le header X-API-Key. Vide = endpoint désactivé.
CLIENT_API_KEY=

# ============ API action client (/api/clients/block) ============
# Clé ADMIN séparée requise dans le header X-Admin-Key pour bloquer/débloquer
# un client sur le routeur. Vide = endpoint désactivé.
ADMIN_API_KEY=

# ============ Workers ============
N_WORKERS=2
WORKER_POLL_INTERVAL=1.0
UNDERPAYMENT_TOLERANCE=150

# ============ Dashboard de supervision (/dashboard) ============
# Mot de passe d'accès à l'interface web de visualisation (lecture seule).
# Vide = dashboard désactivé (login refusé, API → 401).
DASHBOARD_PASSWORD=
